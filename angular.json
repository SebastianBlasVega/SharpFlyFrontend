{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "bun",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "sharpfly": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.css"
            ],
            "server": "src/main.server.ts",
            "outputMode": "server",
            "ssr": {
              "entry": "src/server.ts"
            }
          },
          "configurations": {
            "production": {
  "optimization": {
    "scripts": true,
    "styles": true,
    "fonts": false,
    "fonts": {
      "inline": false
    }
  },
  "budgets": [
  {
    "type": "initial",
    "maximumWarning": "650kB",
    "maximumError": "750kB"
  },
  {
    "type": "anyComponentStyle",
    "maximumWarning": "8kB",  
    "maximumError": "14kB"      
  }
],
  "outputHashing": "all"
},
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "sharpfly:build:production"
            },
            "development": {
              "buildTarget": "sharpfly:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}